digraph G {
  graph [bgcolor="#0a0a0a" fontcolor="#00FFFF" fontname="Courier New" labelloc=t label="Optimized Dual-GPU Residency Architecture (Final)"];
  node  [style=filled fillcolor="#1a1a1a" color="#00FFFF" fontcolor="#00FFFF" fontname="Courier New" shape=box];
  edge  [color="#FF00FF" penwidth=2.0];

  subgraph cluster_gpu0 {
    label="GPU 0 (RTX 3080 10GB)\n8k Context Cap";
    color="#00FF41";
    fontcolor="#00FF41";
    
    ollama0 [label="Ollama Backend\nPort 11434\nParallel=1" color="#00FF41"];
    m0_residency [label="Multi-Model Residency\n(Total ~8.6GB)" fillcolor="#002200" shape=cylinder];
    m0_reason [label="deepseek-r1:8b" fillcolor="#003300"];
    m0_code [label="qwen3.5:4b" fillcolor="#003300"];
    
    ollama0 -> m0_residency;
    m0_residency -> m0_reason;
    m0_residency -> m0_code;
  }

  subgraph cluster_gpu1 {
    label="GPU 1 (RTX 5080 16GB)\n32k Context enabled";
    color="#FFFF00";
    fontcolor="#FFFF00";
    
    ollama1 [label="Ollama Backend\nPort 11435\nParallel=2" color="#FFFF00"];
    m1_residency [label="Multi-Model Residency\n(Total ~12.7GB)" fillcolor="#222200" shape=cylinder];
    m1_reason [label="deepseek-r1:8b" fillcolor="#333300"];
    m1_code [label="ministral-3:8b" fillcolor="#333300"];
    
    ollama1 -> m1_residency;
    m1_residency -> m1_reason;
    m1_residency -> m1_code;
  }

  PP [label="PaperProcessor.py\n(Fork)" shape=doubleoctagon fillcolor="#330033" color="#FF00FF"];
  W0 [label="Worker 1\n(Pinned: GPU 0)" color="#00FF41"];
  W1 [label="Worker 2\n(Pinned: GPU 1)" color="#FFFF00"];

  PP -> W0;
  PP -> W1;
  W0 -> ollama0 [label="Port 11434"];
  W1 -> ollama1 [label="Port 11435"];
}
