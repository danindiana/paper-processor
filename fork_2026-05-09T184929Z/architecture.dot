digraph G {
  graph [bgcolor="#0a0a0a" fontcolor="#00FFFF" fontname="Courier New" labelloc=t label="Dual-GPU Model Residency Architecture"];
  node  [style=filled fillcolor="#1a1a1a" color="#00FFFF" fontcolor="#00FFFF" fontname="Courier New" shape=box];
  edge  [color="#FF00FF" penwidth=2.0];

  subgraph cluster_gpu0 {
    label="GPU 0 (RTX 3080 10GB)";
    color="#00FF41";
    fontcolor="#00FF41";
    
    ollama0 [label="Ollama Backend\nPort 11434" color="#00FF41"];
    m0_reason [label="deepseek-r1:8b\n(Residency A)" fillcolor="#002200"];
    m0_code [label="qwen3.5:4b\n(Residency B)" fillcolor="#002200"];
    
    ollama0 -> m0_reason;
    ollama0 -> m0_code;
  }

  subgraph cluster_gpu1 {
    label="GPU 1 (RTX 3060 12GB)";
    color="#FFFF00";
    fontcolor="#FFFF00";
    
    ollama1 [label="Ollama Backend\nPort 11435" color="#FFFF00"];
    m1_reason [label="deepseek-r1:8b\n(Residency A)" fillcolor="#222200"];
    m1_code [label="ministral-3:8b\n(Residency B)" fillcolor="#222200"];
    
    ollama1 -> m1_reason;
    ollama1 -> m1_code;
  }

  PP [label="PaperProcessor.py\n(Fork)" shape=doubleoctagon fillcolor="#330033" color="#FF00FF"];
  W0 [label="Worker 1\n(Thread A)" color="#00FF41"];
  W1 [label="Worker 2\n(Thread B)" color="#FFFF00"];

  PP -> W0;
  PP -> W1;
  W0 -> ollama0 [label="Pinning"];
  W1 -> ollama1 [label="Pinning"];
}
