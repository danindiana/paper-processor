digraph FutureDirections {
    rankdir=TB;
    graph [fontname="Helvetica", fontsize=13, label="GPU Thermal Management — Future Directions\nworlock · 2026-05-10", labelloc=t, splines=ortho, pad=0.5];
    node  [fontname="Helvetica", fontsize=11, style=filled, shape=box, margin="0.3,0.15"];
    edge  [fontname="Helvetica", fontsize=10];

    // Root
    ROOT [label="Future Directions\nGPU Thermal Mgmt", shape=doubleoctagon, fillcolor="#1a1a2e", fontcolor=white, fontsize=13];

    // Category clusters
    subgraph cluster_thermal {
        label="Thermal Precision";
        fontname="Helvetica"; fontsize=11; fontcolor="#1a1a2e";
        style=filled; fillcolor="#fdecea"; color="#e94560";

        F1 [label="1. Fan Curve Control\nRTX 5080 (Blackwell)\nnvidia-settings +\nXvfb virtual display", fillcolor="#e94560", fontcolor=white];
        F5 [label="5. Track Blackwell\nDriver Updates\nRe-test -gtt support\nafter driver upgrades", fillcolor="#e94560", fontcolor=white];
    }

    subgraph cluster_automation {
        label="Automation & Profiles";
        fontname="Helvetica"; fontsize=11; fontcolor="#1a1a2e";
        style=filled; fillcolor="#fff8e1"; color="#f5a623";

        F2 [label="2. Per-Workload\nPower Profiles\nInference · Training\nIdle tiers", fillcolor="#f5a623", fontcolor="#1a1a2e"];
        F6 [label="6. Unified Dashboard\nDual-GPU side-by-side\nmode counters +\nthrottle history", fillcolor="#f5a623", fontcolor="#1a1a2e"];
    }

    subgraph cluster_observability {
        label="Observability & Alerting";
        fontname="Helvetica"; fontsize=11; fontcolor="#1a1a2e";
        style=filled; fillcolor="#e3f2fd"; color="#0f3460";

        F3 [label="3. Temp-Triggered\nAlerts\nwall / notify-send\nor webhook on threshold", fillcolor="#0f3460", fontcolor=white];
        F4 [label="4. Netdata Integration\nGPU plugin already\navailable on :19999\nhealth engine alerts", fillcolor="#0f3460", fontcolor=white];
    }

    subgraph cluster_validation {
        label="Validation";
        fontname="Helvetica"; fontsize=11; fontcolor="#1a1a2e";
        style=filled; fillcolor="#e8f5e9"; color="#4caf50";

        F7 [label="7. Full Cold Reboot\nValidation\nConfirm 300W caps +\n70°C target survive boot", fillcolor="#4caf50", fontcolor=white];
    }

    // Priority annotations
    P_HIGH [label="Near-term\n(high value)", shape=note, fillcolor="#ffcdd2", fontsize=10];
    P_MED  [label="Medium-term\n(quality of life)", shape=note, fillcolor="#fff9c4", fontsize=10];
    P_LOW  [label="Long-term\n(nice to have)", shape=note, fillcolor="#c8e6c9", fontsize=10];

    // Edges from root to categories
    ROOT -> F1;
    ROOT -> F2;
    ROOT -> F3;
    ROOT -> F4;
    ROOT -> F5;
    ROOT -> F6;
    ROOT -> F7;

    // Priority groupings
    P_HIGH -> F7 [style=dashed, color="#4caf50"];
    P_HIGH -> F3 [style=dashed, color="#4caf50"];
    P_MED  -> F1 [style=dashed, color="#f5a623"];
    P_MED  -> F2 [style=dashed, color="#f5a623"];
    P_LOW  -> F4 [style=dashed, color="#9e9e9e"];
    P_LOW  -> F5 [style=dashed, color="#9e9e9e"];
    P_LOW  -> F6 [style=dashed, color="#9e9e9e"];
}
