digraph HowTo {
    rankdir=LR;
    graph [fontname="Helvetica", fontsize=13, label="GPU Thermal Management — How-To Workflow\nworlock · 2026-05-10", labelloc=t, pad=0.5];
    node  [fontname="Helvetica", fontsize=11, style=filled, shape=box, margin="0.3,0.15"];
    edge  [fontname="Helvetica", fontsize=10, color="#444444"];

    // Start
    START [label="Start:\nCheck GPU\nThermal Support", shape=oval, fillcolor="#1a1a2e", fontcolor=white];

    // Decision: -gtt supported?
    DEC1 [label="-gtt supported?\n(SUPPORTED_GPU_TARGET_TEMP)", shape=diamond, fillcolor="#f5a623", fontcolor="#1a1a2e"];

    // Ampere path
    GTT [label="Set Target Temp\nnvidia-smi -i 1 -gtt 70", fillcolor="#0f3460", fontcolor=white];

    // Blackwell path
    NOCAP [label="No -gtt support\n(Blackwell)", fillcolor="#e94560", fontcolor=white];
    PLCAP [label="Set Power Cap\nnvidia-smi -i 0 -pl 300", fillcolor="#e94560", fontcolor=white];

    // Common path
    VERIFY1 [label="Verify Settings\nnvidia-smi query\ntemp + power.limit", fillcolor="#16213e", fontcolor=white];

    // Script update
    SCRIPT [label="Update\ngpu_power_toggle.sh\neco + perf modes", fillcolor="#0f3460", fontcolor=white];

    // Watchdog check
    WD [label="Inspect\ngpu-watchdog logs\njournalctl -u gpu-watchdog", fillcolor="#0f3460", fontcolor=white];
    WDDEC [label="Watchdog\noverriding caps?", shape=diamond, fillcolor="#f5a623", fontcolor="#1a1a2e"];
    WDFIX [label="Fix perf mode\npower variables\nin toggle script", fillcolor="#e94560", fontcolor=white];

    // Persist
    PERSIST [label="Persist via Systemd\ngpu-eco-mode.service", fillcolor="#1a1a2e", fontcolor=white];
    RESTART [label="Restart Service\nsystemctl restart\ngpu-eco-mode.service", fillcolor="#0f3460", fontcolor=white];
    VERIFY2 [label="Verify Post-Restart\ntemp · power.limit\ntarget temp", fillcolor="#16213e", fontcolor=white];

    // Monitor
    MONITOR [label="Monitor Live\nwatch -n 2 nvidia-smi\nor Claude Code monitor", fillcolor="#0f3460", fontcolor=white];
    DONE [label="Settings Active\n& Persistent", shape=oval, fillcolor="#4caf50", fontcolor=white];

    // Edges
    START -> DEC1;
    DEC1 -> GTT   [xlabel="Yes (Ampere)", color="#4caf50"];
    DEC1 -> NOCAP [xlabel="No (Blackwell)", color="#e94560"];
    NOCAP -> PLCAP;
    GTT   -> VERIFY1;
    PLCAP -> VERIFY1;
    VERIFY1 -> SCRIPT;
    SCRIPT -> WD;
    WD -> WDDEC;
    WDDEC -> WDFIX   [xlabel="Yes", color="#e94560"];
    WDDEC -> PERSIST [xlabel="No",  color="#4caf50"];
    WDFIX -> SCRIPT;
    PERSIST -> RESTART;
    RESTART -> VERIFY2;
    VERIFY2 -> MONITOR;
    MONITOR -> DONE;
}
