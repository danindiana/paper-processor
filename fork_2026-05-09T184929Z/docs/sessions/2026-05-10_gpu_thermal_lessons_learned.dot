digraph LessonsLearned {
    rankdir=TB;
    graph [fontname="Helvetica", fontsize=13, label="GPU Thermal Management — Lessons Learned\nworlock · 2026-05-10", labelloc=t, splines=ortho, pad=0.5];
    node  [fontname="Helvetica", fontsize=11, style=filled, shape=box, margin="0.3,0.15"];
    edge  [fontname="Helvetica", fontsize=10];

    // Root
    ROOT [label="Dual-GPU Thermal\nManagement\nLessons", shape=doubleoctagon, fillcolor="#1a1a2e", fontcolor=white, fontsize=13];

    // Lesson nodes
    L1 [label="1. Arch Differences\nBlackwell vs Ampere\nexpose different\nthermal APIs", fillcolor="#e94560", fontcolor=white];
    L2 [label="2. Power Cap =\nUniversal Fallback\n-pl works when\n-gtt does not", fillcolor="#e94560", fontcolor=white];
    L3 [label="3. Watchdog Silently\nLifts Power Limits\nperf mode resets\ncaps under load", fillcolor="#f5a623", fontcolor="#1a1a2e"];
    L4 [label="4. Locked Clocks\nvs -gtt Scaling\neco mode locks out\ndriver throttling", fillcolor="#f5a623", fontcolor="#1a1a2e"];
    L5 [label="5. Systemd Oneshot\n= Right Persistence\nAfter=nvidia-persistenced\nRemainAfterExit=yes", fillcolor="#0f3460", fontcolor=white];
    L6 [label="6. Service Restart\n≠ Manual Apply\nboth must be tested\nindependently", fillcolor="#0f3460", fontcolor=white];

    // Detail nodes
    D1a [label="RTX 5080 (Blackwell)\nGPU Target Temp: N/A\nMin/Max: N/A", shape=note, fillcolor="#fdecea", fontsize=10];
    D1b [label="RTX 3080 (Ampere)\nGPU Target Temp: 70°C\nRange: 65–91°C", shape=note, fillcolor="#e8f5e9", fontsize=10];
    D2  [label="5080: 360W → 300W\nheld 66–70°C under load\nno throttle events", shape=note, fillcolor="#fdecea", fontsize=10];
    D3  [label="gpu-watchdog calls\ngpu_power_toggle.sh perf\nwhich reset -pl to 360W", shape=note, fillcolor="#fff8e1", fontsize=10];
    D5  [label="gpu-eco-mode.service\nruns at boot after\nnvidia-persistenced", shape=note, fillcolor="#e3f2fd", fontsize=10];

    // Edges
    ROOT -> L1;
    ROOT -> L2;
    ROOT -> L3;
    ROOT -> L4;
    ROOT -> L5;
    ROOT -> L6;

    L1 -> D1a;
    L1 -> D1b;
    L2 -> D2;
    L3 -> D3;
    L5 -> D5;
}
