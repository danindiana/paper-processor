digraph wizard_tabs {
  graph [bgcolor="black" rankdir=TB fontname="Courier New"
         label="paper-wizard — TUI state machine"
         labelloc=t fontcolor="#FF00FF" fontsize=16 pad=0.5
         compound=true];
  node  [style=filled fillcolor="#0a0a0a" fontname="Courier New"
         fontsize=11 penwidth=2.0];
  edge  [fontname="Courier New" fontsize=10 penwidth=2.0];

  start [label="paper-wizard"
         color="#FF00FF" fontcolor="#FF00FF" shape=oval];

  subgraph cluster_tabs {
    label="5 tabs — Tab / Shift-Tab to cycle";
    fontcolor="#00FFFF"; color="#00FFFF"; style=dashed;

    t1 [label="① Overview\npipeline description\n+ health panel (F5)"
        color="#00FF41" fontcolor="#00FF41" shape=box];
    t2 [label="② Scan\nrecursive rglob\nstatus from metadata.json"
        color="#00FFFF" fontcolor="#00FFFF" shape=box];
    t3 [label="③ Config\npapers_dir · model\nbackend · paper · reprocess"
        color="#FFFF00" fontcolor="#FFFF00" shape=box];
    t4 [label="④ Run\nspawn subprocess\nlive colour log"
        color="#FF6600" fontcolor="#FF6600" shape=box];
    t5 [label="⑤ Help\nkeybindings ref"
        color="#DA70FF" fontcolor="#DA70FF" shape=box];
  }

  health [label="GET /api/tags\ndot -V · nvidia-smi\nimport fitz,requests"
          color="#7FFF00" fontcolor="#7FFF00" shape=component];
  subproc [label="python paper_processor.py\n(stdout piped via mpsc)"
          color="#FF0055" fontcolor="#FF0055" shape=component];
  logs   [label="log pane\nemoji-highlighted\nautoscroll · kill"
          color="#FF6600" fontcolor="#FF6600" shape=note];
  select [label="Enter on a row\n→ queue paper"
          color="#00FFFF" fontcolor="#00FFFF" shape=note];

  start -> t1 [color="#FF00FF"];
  t1 -> health [color="#7FFF00" label="F5" fontcolor="#7FFF00"];
  t2 -> select [color="#00FFFF" style=dashed];
  select -> t3 [color="#00FFFF" style=dashed label="prefill --paper" fontcolor="#00FFFF"];
  t3 -> t4 [color="#FFFF00" label="Enter"];
  t4 -> subproc [color="#FF0055" label="L" fontcolor="#FF0055" penwidth=3.0];
  subproc -> logs [color="#FF6600" label="stream" fontcolor="#FF6600"];
  t4 -> subproc [color="#FF0055" label="X = kill" style=dashed arrowhead=tee];

  t1 -> t2 [color="#555555" style=dashed label="Tab"];
  t2 -> t3 [color="#555555" style=dashed label="Tab"];
  t3 -> t4 [color="#555555" style=dashed label="Tab"];
  t4 -> t5 [color="#555555" style=dashed label="Tab"];
  t5 -> t1 [color="#555555" style=dashed label="Tab"];
}
