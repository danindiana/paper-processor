digraph architecture {
  graph [bgcolor="black" rankdir=LR fontname="Courier New"
         label="paper-processor — system architecture"
         labelloc=t fontcolor="#00FF41" fontsize=16 pad=0.5];
  node  [style=filled fillcolor="#0a0a0a" fontname="Courier New"
         fontsize=11 penwidth=2.0];
  edge  [fontname="Courier New" fontsize=10 penwidth=2.0];

  subgraph cluster_ui {
    label="User Interface"; fontcolor="#FF00FF"; color="#FF00FF"; style=dashed;
    wizard  [label="paper-wizard\n(Ratatui TUI)"       color="#FF00FF" fontcolor="#FF00FF" shape=box3d];
    cli     [label="python paper_processor.py\n(direct CLI)" color="#FF00FF" fontcolor="#FF00FF" shape=box];
  }

  subgraph cluster_py {
    label="Python Pipeline"; fontcolor="#00FFFF"; color="#00FFFF"; style=dashed;
    pdf     [label="PyMuPDF\nextract + chunk"   color="#00FFFF" fontcolor="#00FFFF" shape=cylinder];
    proc    [label="PaperProcessor\n5 sections"   color="#00FFFF" fontcolor="#00FFFF" shape=component];
    meta    [label="metadata.json\n(resume state)" color="#7FFF00" fontcolor="#7FFF00" shape=note];
    dot     [label="Graphviz dot\n→ SVG"           color="#FFFF00" fontcolor="#FFFF00" shape=parallelogram];
  }

  subgraph cluster_llm {
    label="Local LLM Backend"; fontcolor="#FF6600"; color="#FF6600"; style=dashed;
    ollama  [label="Ollama\n127.0.0.1:11434" color="#FF6600" fontcolor="#FF6600" shape=doubleoctagon];
    g3080   [label="RTX 3080\n10 GiB VRAM"   color="#00FF41" fontcolor="#00FF41" shape=box];
    g3060   [label="RTX 3060\n12 GiB VRAM"   color="#00FF41" fontcolor="#00FF41" shape=box];
  }

  subgraph cluster_out {
    label="Per-paper Dossier"; fontcolor="#DA70FF"; color="#DA70FF"; style=dashed;
    md      [label="01_summary.md\n02_symbolic_logic.md\n03_cpp_examples.md\n04_extras.md"
             color="#DA70FF" fontcolor="#DA70FF" shape=folder];
    diag    [label="diagrams/\n6 × .dot + .svg" color="#FFFF00" fontcolor="#FFFF00" shape=folder];
  }

  wizard -> cli    [color="#FF00FF" label="spawn"];
  cli    -> pdf    [color="#00FFFF"];
  pdf    -> proc   [color="#00FFFF" label="pages"];
  proc   -> ollama [color="#FF6600" label="POST /api/generate" fontcolor="#FF6600"];
  ollama -> g3080  [color="#00FF41" label="layers 0..n"  fontcolor="#00FF41"];
  ollama -> g3060  [color="#00FF41" label="layers n..49" fontcolor="#00FF41"];
  ollama -> proc   [color="#FF0055" label="response"     fontcolor="#FF0055"];
  proc   -> md     [color="#DA70FF"];
  proc   -> dot    [color="#FFFF00" label="DOT blocks"];
  dot    -> diag   [color="#FFFF00"];
  proc   -> meta   [color="#7FFF00"];
  meta   -> proc   [color="#7FFF00" style=dashed label="resume" fontcolor="#7FFF00"];
}
