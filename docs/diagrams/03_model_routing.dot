digraph model_routing {
  graph [bgcolor="black" rankdir=LR fontname="Courier New"
         label="Model auto-selection by page count"
         labelloc=t fontcolor="#FFFF00" fontsize=16 pad=0.5];
  node  [style=filled fillcolor="#0a0a0a" fontname="Courier New"
         fontsize=11 penwidth=2.0];
  edge  [fontname="Courier New" fontsize=10 penwidth=2.0];

  pdf   [label="PDF\npage_count = N" color="#00FFFF" fontcolor="#00FFFF" shape=cylinder];
  gate  [label="select_model(N)" color="#FFFF00" fontcolor="#FFFF00" shape=diamond];

  subgraph cluster_tiers {
    label="Model tiers"; fontcolor="#FF00FF"; color="#FF00FF"; style=dashed;

    fast  [label="deepseek-r1:8b\n~5 GiB · fits 1× 3060"
           color="#00FF41" fontcolor="#00FF41" shape=box];
    mid   [label="deepseek-r1:14b\n~9 GiB · single-GPU"
           color="#00FFFF" fontcolor="#00FFFF" shape=box];
    xl    [label="gemma4:31b-it-q4_K_M\n~18 GiB · dual-GPU\nbest reasoning"
           color="#FF00FF" fontcolor="#FF00FF" shape=box3d];
    code  [label="qwen3-coder:30b\n~17 GiB · dual-GPU\nC++ stage only"
           color="#DA70FF" fontcolor="#DA70FF" shape=box3d];
  }

  g3080 [label="RTX 3080\n10 GiB" color="#FF6600" fontcolor="#FF6600" shape=box];
  g3060 [label="RTX 3060\n12 GiB" color="#FF6600" fontcolor="#FF6600" shape=box];

  pdf -> gate [color="#00FFFF"];

  gate -> fast [label="N ≤ 8"   color="#00FF41" fontcolor="#00FF41"];
  gate -> mid  [label="N ≤ 18"  color="#00FFFF" fontcolor="#00FFFF"];
  gate -> xl   [label="N > 18"  color="#FF00FF" fontcolor="#FF00FF" penwidth=3.0];
  gate -> code [label="stage 3\n(always)" color="#DA70FF" fontcolor="#DA70FF" style=dashed];

  fast -> g3060 [color="#FF6600"];
  mid  -> g3060 [color="#FF6600"];
  xl   -> g3080 [color="#FF6600"];
  xl   -> g3060 [color="#FF6600"];
  code -> g3080 [color="#FF6600"];
  code -> g3060 [color="#FF6600"];
}
