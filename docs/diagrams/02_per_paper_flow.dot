digraph per_paper_flow {
  graph [bgcolor="black" rankdir=TB fontname="Courier New"
         label="Per-paper processing flow"
         labelloc=t fontcolor="#00FFFF" fontsize=16 pad=0.5];
  node  [style=filled fillcolor="#0a0a0a" fontname="Courier New"
         fontsize=11 penwidth=2.0];
  edge  [fontname="Courier New" fontsize=10 penwidth=2.0 color="#FF00FF"];

  pdf      [label="PDF on disk" shape=note color="#00FFFF" fontcolor="#00FFFF"];
  extract  [label="extract_pages()\nPyMuPDF → List[str]" color="#00FFFF" fontcolor="#00FFFF" shape=box];
  chunk    [label="build_chunks()\nsliding window\nwindow=12  overlap=2"
            color="#FF6600" fontcolor="#FF6600" shape=box];
  mapred   [label="map_reduce_chunks()\nper-chunk summary\n→ condensed context"
            color="#FF6600" fontcolor="#FF6600" shape=box];
  pick     [label="select_model(page_count)\n≤8→8b · ≤18→14b · >18→31b"
            color="#FFFF00" fontcolor="#FFFF00" shape=diamond];

  subgraph cluster_sections {
    label="5 prompt stages (independent, resumable)";
    fontcolor="#00FF41"; color="#00FF41"; style=dashed;
    s1 [label="① summary\nmotivation · methods\nresults · limitations"  color="#00FF41" fontcolor="#00FF41" shape=box];
    s2 [label="② symbolic_logic\nformal notation\ntheorems · complexity" color="#00FF41" fontcolor="#00FF41" shape=box];
    s3 [label="③ cpp_examples\nC++20/23\nqwen3-coder:30b"                color="#DA70FF" fontcolor="#DA70FF" shape=box];
    s4 [label="④ diagrams\n6 neon DOT blocks\ndot → SVG"                 color="#FFFF00" fontcolor="#FFFF00" shape=box];
    s5 [label="⑤ extras\nopen questions\ncritique · connections"         color="#00FF41" fontcolor="#00FF41" shape=box];
  }

  meta  [label="metadata.json\nhash · model · sections_completed"
         color="#7FFF00" fontcolor="#7FFF00" shape=note];
  done  [label="✔ dossier complete" color="#FF0055" fontcolor="#FF0055" shape=doublecircle];

  pdf -> extract;
  extract -> chunk;
  chunk -> mapred [label="if > window"];
  chunk -> pick   [label="if ≤ window" style=dashed];
  mapred -> pick;

  pick -> s1; pick -> s2; pick -> s3 [label="code model" color="#DA70FF" fontcolor="#DA70FF"];
  pick -> s4; pick -> s5;

  s1 -> meta; s2 -> meta; s3 -> meta; s4 -> meta; s5 -> meta;
  meta -> done [color="#FF0055"];
}
